# Application URLs (used for launcher cards)
NEXT_PUBLIC_MOSS_URL=http://moss.localhost
NEXT_PUBLIC_REPO_URL=http://repo.localhost
NEXT_PUBLIC_PORTAL_URL=http://apps.localhost
