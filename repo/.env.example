# PostgreSQL
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_DB=gateway
DATABASE_URL=postgresql://gateway:change-this-database-password@localhost:5432/gateway
DB_SYNCHRONIZE=true

# API and authentication
API_PORT=4000
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AUTH_DISABLED=false
CORS_ORIGIN=http://localhost:8080
MAX_UPLOAD_MB=100

# VPS repository storage
# Local development: ./storage
# VPS example: /opt/physical-risk/repository-gateway-data
VPS_REPOSITORY_PATH=./storage
STORAGE_ROOT=../../storage

# Seeded administrator
DEFAULT_ADMIN_EMAIL=admin@physicalrisk.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_DEMO_PASSWORD

# Frontend. Docker/Nginx uses the same-origin /api route.
NEXT_PUBLIC_API_URL=/api

# Host port exposed by the bundled Nginx reverse proxy
GATEWAY_HTTP_PORT=8080
