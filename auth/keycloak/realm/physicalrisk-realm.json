      "firstName": "Test",
      "lastName": "Analyst",
      "realmRoles": [
        "portal_user",
        "moss_analyst",
        "repo_importer"
      ]
    },
    {
      "username": "client@physicalrisk.local",
      "email": "client@physicalrisk.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "Client",
      "realmRoles": [
        "portal_user",
        "moss_client",
        "repo_viewer"
      ]
    }
  ],
  "scopeMappings": [],
  "clientScopeMappings": {},
  "smtpServer": {},
  "loginTheme": "physicalrisk",
  "accountTheme": "physicalrisk",
  "internationalizationEnabled": false,
  "supportedLocales": [
    "en"
  ],
  "defaultLocale": "en"
}
