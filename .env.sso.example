# Environment
NODE_ENV=development

# Keycloak — public issuer only (never keycloak:8080 for Auth.js)
# Server/client demo: use .env.sso.production.example (physicalrisk.com)
KEYCLOAK_HOSTNAME=auth.localhost
KEYCLOAK_URL=http://auth.localhost
KEYCLOAK_REALM=physicalrisk
KEYCLOAK_ISSUER=http://auth.localhost/realms/physicalrisk

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin@2026

KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=change-this-local-database-password

# Portal
PORTAL_URL=http://apps.localhost
PORTAL_KEYCLOAK_CLIENT_ID=physicalrisk-portal
PORTAL_KEYCLOAK_CLIENT_SECRET=change-this-local-portal-secret
PORTAL_AUTH_SECRET=change-this-long-random-auth-secret

# MOSS
MOSS_WEB_URL=http://moss.localhost
MOSS_KEYCLOAK_CLIENT_ID=physicalrisk-moss
MOSS_KEYCLOAK_CLIENT_SECRET=change-this-local-moss-secret
MOSS_AUTH_SECRET=moss-local-nextauth-secret-change-me
MOSS_CORS_ORIGINS=http://moss.localhost,http://localhost:3001,http://apps.localhost
CONTACT_NOTIFICATION_TO=info@physicalrisk.com
CONTACT_FROM_EMAIL=no-reply@physicalrisk.com
CONTACT_PROGRAMME_OPTIONS=MOSS Assessment
CONTACT_ALLOWED_ORIGINS=http://test.localhost
CONTACT_ALLOWED_HOSTS=test.localhost
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
ESPO_LEAD_PROGRAMME_FIELD=
ESPO_LEAD_SOURCE_FIELD=source
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Repository
REPO_WEB_URL=http://repo.localhost
REPO_KEYCLOAK_CLIENT_ID=physicalrisk-repo
REPO_KEYCLOAK_CLIENT_SECRET=change-this-local-repo-secret
REPO_AUTH_SECRET=repo-local-nextauth-secret-change-me
REPO_CORS_ORIGINS=http://repo.localhost,http://localhost:3002,http://apps.localhost

# Shared
ENABLE_LEGACY_LOGIN=false
SSO_COOKIE_SECURE=false
SSO_COOKIE_SAME_SITE=lax
SSO_SESSION_MAX_AGE=28800
SSO_DEBUG=false

# Nginx
NGINX_HTTP_PORT=80
