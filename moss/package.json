{
  "name": "moss-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @moss/api --filter @moss/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @moss/api prisma:generate",
    "db:migrate": "pnpm --filter @moss/api prisma:migrate",
    "db:seed": "pnpm --filter @moss/api prisma:seed"
  }
}
