# Core
NODE_ENV=development
APP_NAME=MOSS
PUBLIC_URL=http://localhost:8081
WEB_URL=http://localhost:8081
API_URL=http://api:4000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WORDPRESS_URL=https://test.physicalrisk.com

# Database / cache
POSTGRES_DB=moss
POSTGRES_USER=moss
POSTGRES_PASSWORD=change_me_now
DATABASE_URL=postgresql://moss:change_me_now@postgres:5432/moss?schema=public
REDIS_URL=redis://redis:6379

# Security
JWT_SECRET=REDACTED_JWT_SECRET
JWT_EXPIRES_IN=8h
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:8080
SEED_ADMIN_EMAIL=admin@physicalrisk.local
SEED_ADMIN_PASSWORD=REDACTED_SEED_ADMIN_PASSWORD

# Evidence / report storage (S3-compatible MinIO)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=REDACTED_S3_ACCESS_KEY
S3_SECRET_KEY=REDACTED_S3_SECRET_KEY
S3_BUCKET=moss-evidence
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=REDACTED_S3_ACCESS_KEY
MINIO_ROOT_PASSWORD=REDACTED_S3_SECRET_KEY

# SMTP
# Outbound email (optional). Admins can also configure SMTP in Settings → Email Configuration.
# Saved admin settings override these env defaults at runtime.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MOSS <no-reply@example.com>
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=MOSS
LEAD_NOTIFY_EMAIL=

# Public WordPress contact / Book a MOSS Assessment
CONTACT_NOTIFICATION_TO=
CONTACT_FROM_EMAIL=
CONTACT_PROGRAMME_OPTIONS=
CONTACT_ALLOWED_ORIGINS=
CONTACT_ALLOWED_HOSTS=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
ESPO_LEAD_PROGRAMME_FIELD=
ESPO_LEAD_SOURCE_FIELD=

# EspoCRM (third-party instance, separate from the MOSS VPS)
# Never expose ESPOCRM_API_KEY to the browser / NEXT_PUBLIC_* vars.
# Admins can also set Base URL + API Key in Settings → EspoCRM Integration (overrides these defaults).
ESPOCRM_ENABLED=false
ESPOCRM_BASE_URL=https://crm.example.com
ESPOCRM_API_KEY=
ESPOCRM_TIMEOUT=15000
ESPOCRM_TIMEOUT_MS=15000
ESPOCRM_VERIFY_SSL=true
ESPOCRM_VERIFY_TLS=true
ESPOCRM_AUTO_SYNC=true
ESPOCRM_FOLLOW_UP_DAYS=2
ESPOCRM_DEFAULT_ASSIGNED_USER_ID=
ESPOCRM_WEBHOOK_SECRET=

# Custom field API names (Entity Manager → field Name)
ESPOCRM_ACCOUNT_MOSS_ID_FIELD=cMossOrganisationId
ESPOCRM_CONTACT_MOSS_ID_FIELD=cMossContactId
ESPOCRM_OPPORTUNITY_MOSS_ID_FIELD=cMossAssessmentId
ESPOCRM_LEAD_MOSS_REF_FIELD=cMossAssessmentReference
ESPOCRM_ACCOUNT_SITES_FIELD=
ESPOCRM_ACCOUNT_CONTRACT_VALUE_FIELD=

ESPOCRM_OPPORTUNITY_SCLI_SCORE_FIELD=cMossScliScore
ESPOCRM_OPPORTUNITY_RISK_RATING_FIELD=cMossRiskRating
ESPOCRM_OPPORTUNITY_GOVERNANCE_SCORE_FIELD=cMossGovernanceScore
ESPOCRM_OPPORTUNITY_CONFIDENCE_SCORE_FIELD=cMossConfidenceScore
ESPOCRM_OPPORTUNITY_OPPORTUNITY_SCORE_FIELD=cMossOpportunityScore
ESPOCRM_OPPORTUNITY_MIN_LEAKAGE_FIELD=cMossMinimumLeakage
ESPOCRM_OPPORTUNITY_LIKELY_LEAKAGE_FIELD=cMossLikelyLeakage
ESPOCRM_OPPORTUNITY_MAX_EXPOSURE_FIELD=cMossMaximumExposure
ESPOCRM_OPPORTUNITY_RECOVERABLE_LOW_FIELD=cMossRecoverableLow
ESPOCRM_OPPORTUNITY_RECOVERABLE_HIGH_FIELD=cMossRecoverableHigh
ESPOCRM_OPPORTUNITY_HIGHEST_RISK_FIELD=cMossHighestRiskCategory
ESPOCRM_OPPORTUNITY_RECOMMENDED_SERVICE_FIELD=cMossRecommendedService
ESPOCRM_OPPORTUNITY_STATUS_FIELD=cMossAssessmentStatus
ESPOCRM_OPPORTUNITY_REPORT_URL_FIELD=cMossReportUrl
ESPOCRM_OPPORTUNITY_REFERENCE_FIELD=cMossAssessmentReference

# Optional stage overrides (MOSS status → EspoCRM Opportunity stage)
ESPOCRM_STAGE_DRAFT=Prospecting
ESPOCRM_STAGE_IN_PROGRESS=Prospecting
ESPOCRM_STAGE_SUBMITTED=Qualification
ESPOCRM_STAGE_REVIEWED=Qualification
ESPOCRM_STAGE_APPROVED=Proposal
ESPOCRM_STAGE_REPORT_GENERATED=Proposal
ESPOCRM_STAGE_REPORT_ISSUED=Negotiation

# Legacy aliases (still supported)
ESPOCRM_FIELD_SCLI_SCORE=cMossScliScore
ESPOCRM_FIELD_RISK_BAND=cMossRiskRating
ESPOCRM_FIELD_LIKELY_LEAKAGE=cMossLikelyLeakage
ESPOCRM_FIELD_RECOVERABLE_LOW=cMossRecoverableLow
ESPOCRM_FIELD_RECOVERABLE_HIGH=cMossRecoverableHigh
ESPOCRM_FIELD_REPORT_URL=cMossReportUrl
