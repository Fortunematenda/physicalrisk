# Copy to .env.sso on the server (never commit real secrets).
# Domain layout for physicalrisk.com client testing.

NODE_ENV=production

# Public hostnames (DNS A/AAAA records must point here)
KEYCLOAK_HOSTNAME=auth.physicalrisk.com
KEYCLOAK_URL=https://auth.physicalrisk.com
KEYCLOAK_REALM=physicalrisk
KEYCLOAK_ISSUER=https://auth.physicalrisk.com/realms/physicalrisk

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Portal launcher
PORTAL_URL=https://apps.physicalrisk.com
PORTAL_KEYCLOAK_CLIENT_ID=physicalrisk-portal
PORTAL_KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_PORTAL_CLIENT_SECRET
PORTAL_AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# MOSS
MOSS_WEB_URL=https://moss.physicalrisk.com
MOSS_KEYCLOAK_CLIENT_ID=physicalrisk-moss
MOSS_KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_MOSS_CLIENT_SECRET
MOSS_AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
MOSS_CORS_ORIGINS=https://moss.physicalrisk.com,https://apps.physicalrisk.com,https://test.physicalrisk.com
CONTACT_NOTIFICATION_TO=info@physicalrisk.com
CONTACT_FROM_EMAIL=no-reply@physicalrisk.com
CONTACT_PROGRAMME_OPTIONS=MOSS Assessment
CONTACT_ALLOWED_ORIGINS=https://test.physicalrisk.com
CONTACT_ALLOWED_HOSTS=test.physicalrisk.com
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
ESPO_LEAD_PROGRAMME_FIELD=
ESPO_LEAD_SOURCE_FIELD=source
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Repository
REPO_WEB_URL=https://repo.physicalrisk.com
REPO_KEYCLOAK_CLIENT_ID=physicalrisk-repo
REPO_KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_REPO_CLIENT_SECRET
REPO_AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
REPO_CORS_ORIGINS=https://repo.physicalrisk.com,https://apps.physicalrisk.com

# Shared
ENABLE_LEGACY_LOGIN=false
SSO_COOKIE_SECURE=true
SSO_COOKIE_SAME_SITE=lax
SSO_SESSION_MAX_AGE=28800
SSO_DEBUG=false

# Nginx (compose proxy). Put TLS in front (Cloudflare / host nginx / Caddy).
NGINX_HTTP_PORT=80
